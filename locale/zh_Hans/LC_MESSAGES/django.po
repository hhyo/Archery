msgid "exists key checks whether key exists. Returns 1 if it exists, otherwise 0."
msgstr "exists key 检查 key 是否存在。存在返回 1，否则返回 0。"

msgid "keys pattern finds all keys matching the given pattern and is usually used to search keys."
msgstr "keys pattern 查找匹配指定模式的所有 key，通常用于搜索 key。"

msgid "expire key seconds sets a timeout for key in seconds. The system deletes it automatically when it expires."
msgstr "expire key seconds 为 key 设置秒级超时时间，到期后自动删除。"

msgid "ttl key returns the remaining lifetime of key in seconds. Returns -2 if key does not exist and -1 if it exists without an expiry."
msgstr "ttl key 返回 key 剩余生存时间（秒）。key 不存在返回 -2，不设置过期时间返回 -1。"

msgid "pttl key works like ttl but returns the remaining lifetime in milliseconds."
msgstr "pttl key 类似 ttl，但返回毫秒级剩余时间。"

msgid "move key db moves key to the specified database."
msgstr "move key db 将 key 移动到指定数据库。"

msgid "type key returns the stored value type: none (missing), string, list, set, zset, or hash."
msgstr "type key 返回 key 存储的值类型：none（不存在）、string、list、set、zset 或 hash。"

msgid "get key returns the value of key. Returns nil if key does not exist and an error if the value is not a string."
msgstr "get key 返回 key 的值。key 不存在返回 nil，值不是字符串时返回错误。"

msgid "mget key [key...] returns one or more values by key. Missing keys return nil."
msgstr "mget key [key...] 根据 key 返回一个或多个值。缺失的 key 返回 nil。"

msgid "strlen key returns the string length stored at key. Returns 0 if key does not exist and an error if the value is not a string."
msgstr "strlen key 返回 key 中字符串长度。key 不存在返回 0，值不是字符串时返回错误。"

msgid "append key value appends a value to the end of key, creating it if needed, and returns the new string length."
msgstr "append key value 将 value 追加到 key 末尾；如有需要会先创建 key，并返回新的字符串长度。"

msgid "set key value [ex seconds] [px milliseconds] [nx|xx] sets a value for key. ex and px set expiry in different units. nx only works when the key does not exist and xx only works when it does."
msgstr "set key value [ex seconds] [px milliseconds] [nx|xx] 为 key 设置值。ex 和 px 分别设置不同单位的过期时间。nx 仅在 key 不存在时生效，xx 仅在 key 存在时生效。"

msgid "setex key seconds value sets a key value with a lifetime in seconds."
msgstr "setex key seconds value 为 key 设置值并指定秒级存活时间。"

msgid "setnx key value sets a key value only when the key does not already exist."
msgstr "setnx key value 仅在 key 不存在时设置值。"

msgid "mset key value [key value...] atomically sets one or more key-value pairs. It succeeds or fails as a unit."
msgstr "mset key value [key value...] 原子地设置一个或多个键值对。要么全部成功，要么全部失败。"

msgid "msetnx key value [key value...] is like mset, but all keys must be missing or the operation fails."
msgstr "msetnx key value [key value...] 类似 mset，但所有 key 都必须不存在，否则操作失败。"

msgid "hgetall key returns all field values in the hash."
msgstr "hgetall key 返回 hash 中所有字段和值。"

msgid "hexists key field checks whether a field exists in the hash. Returns 1 if yes, otherwise 0."
msgstr "hexists key field 检查 hash 中是否存在字段。存在返回 1，否则返回 0。"

msgid "hget key field returns the value of a field in the hash."
msgstr "hget key field 返回 hash 中某个字段的值。"

msgid "hmget key field[field...] returns multiple field values from the hash."
msgstr "hmget key field[field...] 返回 hash 中多个字段的值。"

msgid "hkeys key returns all fields in the hash."
msgstr "hkeys key 返回 hash 中所有字段。"

msgid "hvals key returns all values in the hash."
msgstr "hvals key 返回 hash 中所有值。"

msgid "hdel key field[field...] deletes fields from the hash."
msgstr "hdel key field[field...] 删除 hash 中的字段。"

msgid "hset key field value sets a field-value pair in the hash."
msgstr "hset key field value 在 hash 中设置字段和值。"

msgid "hsetnx key field value works like hset, but only when the field does not already exist."
msgstr "hsetnx key field value 类似 hset，但仅在字段不存在时生效。"

msgid "smembers key lists all members of the set."
msgstr "smembers key 列出 set 中所有成员。"

msgid "scard key returns the number of elements in the set."
msgstr "scard key 返回 set 中元素数量。"

msgid "sdiff key[key...] returns the set difference."
msgstr "sdiff key[key...] 返回集合差集。"

msgid "sunion key[key...] returns the union of sets."
